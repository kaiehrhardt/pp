# Room state storage (Turso / libSQL). Defaults to a local file so `bun run dev`
# and `bun test` work with no external account. Point at a real Turso database
# (or a local `sqld` instance, e.g. via docker-compose) for anything durable.
# TURSO_DATABASE_URL=file:./dev.db
# TURSO_AUTH_TOKEN=

# Cross-pod WebSocket fan-out (Bun.redis pub/sub). Required whenever more than
# one instance of the app is running against the same Turso database.
# REDIS_URL=redis://localhost:6379
